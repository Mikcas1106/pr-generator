{
  "name": "git-report-generator",
  "version": "1.0.0",
  "description": "",
  "main": "electron-main.js",
  "scripts": {
    "predev": "git pull origin main",
    "dev": "node server.js",
    "desktop": "electron .",
    "desktop:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3001 && electron .\"",
    "build:exe": "electron-builder --win nsis",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "body-parser": "^2.2.2",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "wait-on": "^9.0.3"
  },
  "devDependencies": {
    "electron": "^38.3.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.gitreport.generator",
    "productName": "Git Report Pro",
    "files": [
      "electron-main.js",
      "server.js",
      "config.json",
      "public/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron-main.js"
    },
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/favicon.png"
    }
  }
}
